# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# Default rate limit: applies to all endpoints unless overridden
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW_MS=60000

# Per-endpoint overrides (format: RATE_LIMIT_METHOD_PATH=limit)
RATE_LIMIT_POST_LOGIN=10
RATE_LIMIT_POST_SIGNUP=5
RATE_LIMIT_GET_SEARCH=50

# Key strategy: which fields to combine for identifying unique callers
# Options: ip, userId, apiKey, endpoint — comma-separated for combinations
RATE_LIMIT_KEY_STRATEGY=userId,endpoint

# CORS origin (defaults to localhost)
CORS_ORIGIN=http://localhost:3000

# Server port
PORT=3000
